<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <title>Převodník času</title>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,700&display=swap" rel="stylesheet">
    
    <style>
        body { 
            font-family: sans-serif; 
            padding: 20px; 
            line-height: 1.6; 
            background-color: #eef2f3;
        }
        
        /* Styl pro nadpis s novým písmem */
        h2 { 
            font-family: 'Bricolage Grotesque', sans-serif; 
            font-weight: 700;
            color: #2c3e50;
            margin-top: 0;
            letter-spacing: -0.5px;
        }

        .container { 
            max-width: 400px; 
            margin: 40px auto; 
            background: white; 
            padding: 30px; 
            border-radius: 15px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        label {
            font-size: 0.9rem;
            color: #666;
        }

        input { 
            width: 100%; 
            padding: 12px; 
            margin: 10px 0 20px 0; 
            box-sizing: border-box; 
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.3s;
        }

        input:focus {
            border-color: #3498db;
        }

        .result { 
            background: #f8f9fa; 
            padding: 15px; 
            border-radius: 8px; 
            border-left: 4px solid #3498db;
        }

        b { color: #2c3e50; }
    </style>
</head>
<body>

<div class="container">
    <h2>⏱️ Převodník času</h2>
    <label>Zadejte čas (např. 1,5h, 68min, 1h 20m):</label>
    <input type="text" id="timeInput" placeholder="Zkuste třeba 1h 19min" oninput="convertTime()">
    
    <div id="output" class="result">
        Zadejte hodnotu pro výpočet...
    </div>
</div>

<script>
function convertTime() {
    const input = document.getElementById('timeInput').value.toLowerCase().trim().replace(',', '.');
    let totalMinutes = 0;

    // Regulární výrazy pro různé formáty
    const hMatch = input.match(/(\d+\.?\d*)\s*h/);
    const mMatch = input.match(/(\d+\.?\d*)\s*m/);
    
    if (hMatch || mMatch) {
        if (hMatch) totalMinutes += parseFloat(hMatch[1]) * 60;
        if (mMatch) totalMinutes += parseFloat(mMatch[1]);
    } else if (input.includes(':')) {
        const parts = input.split(':');
        totalMinutes = (parseFloat(parts[0]) * 60) + (parseFloat(parts[1]) || 0);
    } else if (input !== "") {
        totalMinutes = parseFloat(input) || 0;
    }

    const outputDiv = document.getElementById('output');

    if (totalMinutes > 0) {
        const h = Math.floor(totalMinutes / 60);
        const m = Math.round(totalMinutes % 60);
        const decimalH = (totalMinutes / 60).toLocaleString('cs-CZ', { maximumFractionDigits: 2 });

        outputDiv.innerHTML = `
            Standardní zápis: <b>${h}h ${m}min</b><br>
            Desetinné hodiny: <b>${decimalH} h</b><br>
            Celkem minut: <b>${Math.round(totalMinutes)} min</b>
        `;
    } else {
        outputDiv.innerHTML = "Zadejte platný časový údaj...";
    }
}
</script>

</body>
</html>
